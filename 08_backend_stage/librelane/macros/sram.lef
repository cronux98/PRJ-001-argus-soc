VERSION 5.8 ;
NAMESCASESENSITIVE ON ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

MACRO sram
  CLASS BLOCK ;
  FOREIGN sram ;
  ORIGIN 0.000 0.000 ;
  SIZE 683.100 BY 416.160 ;
  SYMMETRY X Y R90 ;

  PIN clk_i
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER met1 ;
        RECT 0.000 10.000 0.500 10.500 ;
    END
  END clk_i

  PIN rst_ni
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER met1 ;
        RECT 0.000 20.000 0.500 20.500 ;
    END
  END rst_ni

  PIN imem_addr[0]
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER met1 ;
        RECT 0.000 30.000 0.500 30.500 ;
    END
  END imem_addr[0]

  PIN imem_addr[31]
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER met1 ;
        RECT 0.000 40.000 0.500 40.500 ;
    END
  END imem_addr[31]

  PIN imem_rdata[0]
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER met1 ;
        RECT 682.600 10.000 683.100 10.500 ;
    END
  END imem_rdata[0]

