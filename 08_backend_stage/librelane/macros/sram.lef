  PIN apb_penable
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER met1 ;
        RECT 682.600 130.000 683.100 130.500 ;
    END
  END apb_penable

  PIN apb_pready
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER met1 ;
        RECT 682.600 140.000 683.100 140.500 ;
    END
  END apb_pready

  OBS
    LAYER met1 ;
      RECT 0.000 0.000 683.100 416.160 ;
  END
END sram

END LIBRARY
